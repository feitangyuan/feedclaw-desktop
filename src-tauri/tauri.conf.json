{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "养养龙虾",
  "version": "0.1.0",
  "identifier": "ai.yangyanglongxia.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "养养龙虾",
        "width": 860,
        "height": 620,
        "resizable": false,
        "maximizable": false,
        "fullscreen": false,
        "transparent": false,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "bundleName": "养养龙虾"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
